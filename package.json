{
  "name": "agent-ready",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Agent-Ready Schema — governance layer for AI agents",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "optionalDependencies": {
    "lightningcss-win32-x64-msvc": "1.32.0"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Diego Souza <DiegoSouzadsp> (Orquestra AI)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiegoSouzadsp/agent-ready-core.git"
  }
}
